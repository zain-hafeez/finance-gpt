# ============================================================
# FinanceGPT — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your real values.
# NEVER commit the .env file to Git.
# ============================================================

# --- LLM Provider API Keys ---
# Get your Groq API key (free) at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Get your OpenAI API key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# --- Application Settings ---
# Maximum file size the app will accept (in megabytes)
MAX_FILE_SIZE_MB=10

# How long (in seconds) stats code is allowed to run before timing out
EXECUTION_TIMEOUT_SECONDS=5

# Whether to enable LLM response caching (true/false)
CACHE_ENABLED=true

# Filename for the SQLite database where uploaded data is stored
DB_PATH=finance.db

# Filename for LangGraph conversation history checkpoints
CHECKPOINTS_DB=checkpoints.db


