# Virtual environment — never commit this (it's huge and machine-specific)
venv/
.venv/
env/

# Secret keys — NEVER commit this (your API keys live here)
.env

# Python compiled files — auto-generated, not needed in Git
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Database files — these are runtime-generated, not source code
*.db
*.sqlite
*.sqlite3

# VS Code settings (optional — some prefer to commit these)
.vscode/

# OS-generated files
.DS_Store
Thumbs.db

# Test coverage reports
.coverage
htmlcov/
.pytest_cache/

# Distribution / packaging
dist/
build/
*.egg-info/

# SQLite databases and temp files
finance.db
checkpoints.db
checkpoints.db-shm
checkpoints.db-wal
*.db-shm
*.db-wal